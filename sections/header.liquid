<header
  class="w-full bg-white border-b border-lyra-line relative z-[100]"
  data-section-id="{{ section.id }}"
  data-section-type="header"
>
  <div class="container mx-auto px-4 md:px-8">
    <div class="flex items-center justify-between py-6">
      <div class="flex flex-1 items-center space-x-5">
        <button type="button" class="lg:hidden text-lyra-text" aria-label="Open Menu">
          {% render 'icon-menuIcon' %}
        </button>
        <button type="button" class="hidden lg:block text-lyra-text hover:text-lyra-primary transition-colors">
          {% render 'icon-search' %}
        </button>
      </div>

      <div class="flex-none">
        <a href="/" class="inline-block">
          <h1 class="font-heading text-3xl md:text-4xl font-bold tracking-[0.25em] uppercase text-lyra-text leading-none">
            LYRA
          </h1>
        </a>
      </div>

      <div class="flex flex-1 items-center justify-end space-x-6">
        <a
          href="{{ routes.account_url }}"
          class="hidden md:block text-lyra-text hover:text-lyra-primary transition-colors"
        >
          {% render 'icon-wishlist' %}
        </a>

        <a href="{{ routes.cart_url }}" class="relative text-lyra-text hover:text-lyra-primary transition-colors">
          {% render 'icon-shop' %}
          <span class="absolute -top-2 -right-2 bg-lyra-primary text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-body"
            >0</span
          >
        </a>
        <a
          href="{{ routes.account_url }}"
          class="hidden md:block text-lyra-text hover:text-lyra-primary transition-colors"
        >
          {% render 'icon-account' %}
        </a>
      </div>
    </div>

    <nav class="hidden lg:flex justify-center border-t border-lyra-line/20">
      <ul class="flex items-center">
        {% for link in linklists[section.settings.menu].links %}
          <li class="relative group">
            <a
              href="{{ link.url }}"
              class="h6 !mb-0 px-6 py-5 inline-block text-lyra-text group-hover:text-lyra-primary transition-colors uppercase tracking-[0.18em]"
            >
              {{ link.title }}
              {% if link.links != blank %}
                <svg
                  class="inline-block w-2.5 h-2.5 ml-1 transition-transform group-hover:rotate-180"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path d="M19 9l-7 7-7-7" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              {% endif %}
            </a>

            {% if link.links != blank %}
              <ul class="absolute left-1/2 -translate-x-1/2 top-full w-56 bg-white border border-lyra-line/30 shadow-2xl py-4 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-300 transform group-hover:translate-y-0 translate-y-2 z-[110]">
                {% for childlink in link.links %}
                  <li>
                    <a
                      href="{{ childlink.url }}"
                      class="block px-8 py-2.5 text-[10px] uppercase tracking-[0.2em] text-lyra-text/70 hover:text-lyra-primary hover:bg-lyra-bg transition-all font-body"
                    >
                      {{ childlink.title }}
                    </a>
                  </li>
                {% endfor %}
              </ul>
            {% endif %}
          </li>
        {% endfor %}
      </ul>
    </nav>
  </div>
</header>

{% schema %}
{
  "name": "Header - Dropdown",
  "settings": [
    {
      "type": "link_list",
      "id": "menu",
      "label": "Select Menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
